Функция НормализоватьИмяПоля(ЗначениеПоля)

	Результат = НРег(СокрЛП(Строка(ЗначениеПоля)));
	Результат = СтрЗаменить(Результат, "ё", "е");
	Результат = СтрЗаменить(Результат, " ", "");
	Результат = СтрЗаменить(Результат, "_", "");
	Результат = СтрЗаменить(Результат, "-", "");
	Результат = СтрЗаменить(Результат, ".", "");

	Возврат Результат;

