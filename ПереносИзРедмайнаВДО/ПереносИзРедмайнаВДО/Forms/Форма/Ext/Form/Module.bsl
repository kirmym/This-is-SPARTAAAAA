&НаСервере
Функция ОпределитьРазделитель(Строка)

	СчетчикТаб = КоличествоВхождений(Строка, Символы.Таб);
	СчетчикТочкаСЗапятой = КоличествоВхождений(Строка, ";");
	СчетчикЗапятая = КоличествоВхождений(Строка, ",");

	Если СчетчикТаб >= СчетчикТочкаСЗапятой И СчетчикТаб >= СчетчикЗапятая Тогда
		Возврат Символы.Таб;
	КонецЕсли;

	Если СчетчикТочкаСЗапятой >= СчетчикЗапятая Тогда
		Возврат ";";
	Иначе
		Возврат ",";
	КонецЕсли;

