	СтрокаДляЧисла = СтрЗаменить(СокрЛП(СтрокаЧисла), " ", "");
	СтрокаДляЧисла = СтрЗаменить(СтрокаДляЧисла, ",", ".");

	Попытка
		Возврат Число(СтрокаДляЧисла);
	Исключение
		Возврат 0;
	КонецПопытки;

