&НаСервере
Функция КоличествоВхождений(Знач ИсходнаяСтрока, Знач Подстрока)

	Если ПустаяСтрока(Подстрока) Тогда
		Возврат 0;
	КонецЕсли;

	Позиция = 1;
	Счетчик = 0;
	ДлинаПодстроки = СтрДлина(Подстрока);

	Пока Истина Цикл
		Найдено = Найти(ИсходнаяСтрока, Подстрока, Позиция);
		Если Найдено = 0 Тогда
			Прервать;
		КонецЕсли;

		Счетчик = Счетчик + 1;
		Позиция = Найдено + ДлинаПодстроки;
	КонецЦикла;

	Возврат Счетчик;

КонецФункции

&НаСервере
Функция СоединитьСтроки(Строки, Разделитель)

	Если Строки = Неопределено Или Строки.Количество() = 0 Тогда
		Возврат "";
	КонецЕсли;

	Результат = "";
	Для Индекс = 0 По Строки.Количество() - 1 Цикл
		Если Индекс > 0 Тогда
			Результат = Результат + Разделитель;
		КонецЕсли;
		Результат = Результат + Строка(Строки[Индекс]);
	КонецЦикла;

	Возврат Результат;

КонецФункции

