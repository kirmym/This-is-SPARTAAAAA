#Region ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)

	ИнициализироватьКолонкиТаблицыВыгрузки();
	ЗаполнитьСоответствияИзТаблицыВыгрузки();

КонецПроцедуры

#EndRegion

#Region ОбработчикиКомандФормы

&НаКлиенте
Процедура ЗагрузитьФайлРедмайн(Команда)

	Диалог = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.Открытие);
	Диалог.Фильтр = "Файлы импорта (*.csv;*.xls;*.xlsx)|*.csv;*.xls;*.xlsx";
	Диалог.МножественныйВыбор = Ложь;
	Диалог.Заголовок = "Выберите файл с таймлогом";

	Если Не Диалог.Выбрать() Тогда
		Возврат;
	КонецЕсли;

	ЗагрузитьФайлНаСервере(Диалог.ПолноеИмяФайла);
	СопоставитьСотрудниковНаСервере();
	СопоставитьПроектыНаСервере();

КонецПроцедуры

&НаКлиенте
Процедура СопоставитьСотрудников(Команда)

	СопоставитьСотрудниковНаСервере();

КонецПроцедуры

&НаКлиенте
Процедура СопоставитьПроекты(Команда)

	СопоставитьПроектыНаСервере();

КонецПроцедуры

&НаКлиенте
Процедура СоздатьДокументыДО(Команда)

	РезультатСоздания = СоздатьДокументыДОНаСервере();
	ПоказатьПредупреждение(, РезультатСоздания);

КонецПроцедуры

#EndRegion

#Region СлужебныеПроцедурыИФункции

&НаСервере
Процедура ИнициализироватьКолонкиТаблицыВыгрузки()

	Если ТаблицаВыгрузки = Неопределено Тогда
		ТаблицаВыгрузки = Новый ТаблицаЗначений;
	КонецЕсли;

	Если ТаблицаВыгрузки.Колонки.Найти("СотрудникРедмайн") = Неопределено Тогда
		ТаблицаВыгрузки.Колонки.Добавить("СотрудникРедмайн", Новый ОписаниеТипов("Строка"));
	КонецЕсли;

	Если ТаблицаВыгрузки.Колонки.Найти("ПроектРедмайн") = Неопределено Тогда
		ТаблицаВыгрузки.Колонки.Добавить("ПроектРедмайн", Новый ОписаниеТипов("Строка"));
	КонецЕсли;

КонецПроцедуры

&НаСервере
Процедура ЗагрузитьФайлНаСервере(Знач ПолноеИмяФайла)

	ИнициализироватьКолонкиТаблицыВыгрузки();
	ТаблицаВыгрузки.Очистить();

	ТаблицаCSV = ПрочитатьCSVВТаблицу(ПолноеИмяФайла);
	Если ТаблицаCSV.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;

	Если ЭтоМатричныйФормат(ТаблицаCSV) Тогда
		ЗагрузитьМатричныйФормат(ТаблицаCSV);
	Иначе
		ЗагрузитьПострочныйФормат(ТаблицаCSV);
	КонецЕсли;

	ЗаполнитьСоответствияИзТаблицыВыгрузки();

КонецПроцедуры

&НаСервере
Функция ПрочитатьCSVВТаблицу(ПолноеИмяФайла)

	Текст = Новый ТекстовыйДокумент;
	ТаблицаCSV = Новый ТаблицаЗначений;
	ТаблицаCSV.Колонки.Добавить("Строка");

	Попытка
		Текст.Прочитать(ПолноеИмяФайла, КодировкаТекста.ANSI);
	Исключение
		Текст.Прочитать(ПолноеИмяФайла);
	КонецПопытки;

	Для НомерСтроки = 1 По Текст.КоличествоСтрок() Цикл

		СтрокаCSV = СокрЛП(Текст.ПолучитьСтроку(НомерСтроки));
		Если ПустаяСтрока(СтрокаCSV) Тогда
			Продолжить;
		КонецЕсли;

		НоваяСтрока = ТаблицаCSV.Добавить();
		НоваяСтрока.Строка = СтрокаCSV;

	КонецЦикла;

	Возврат ТаблицаCSV;

КонецФункции

&НаСервере
Функция ЭтоМатричныйФормат(ТаблицаCSV)

	Если ТаблицаCSV.Количество() = 0 Тогда
		Возврат Ложь;
	КонецЕсли;

	ПерваяСтрока = ТаблицаCSV[0].Строка;
	Разделитель = ОпределитьРазделитель(ПерваяСтрока);
	Поля = РазобратьСтроку(ПерваяСтрока, Разделитель);

	Если Поля.Количество() < 4 Тогда
		Возврат Ложь;
	КонецЕсли;

	СчетчикДат = 0;
	Для Индекс = 2 По Поля.Количество() - 1 Цикл
		Если ПреобразоватьСтрокуВДату(Поля[Индекс]) <> Неопределено Тогда
			СчетчикДат = СчетчикДат + 1;
		КонецЕсли;
	КонецЦикла;

	Возврат СчетчикДат >= 2;

КонецФункции

&НаСервере
Процедура ЗагрузитьМатричныйФормат(ТаблицаCSV)

	ПерваяСтрока = ТаблицаCSV[0].Строка;
	Разделитель = ОпределитьРазделитель(ПерваяСтрока);
	Заголовок = РазобратьСтроку(ПерваяСтрока, Разделитель);

	ТекущийСотрудникРедмайн = "";

	Для НомерСтроки = 1 По ТаблицаCSV.Количество() - 1 Цикл

		Поля = РазобратьСтроку(ТаблицаCSV[НомерСтроки].Строка, Разделитель);
		Если Поля.Количество() = 0 Тогда
			Продолжить;
		КонецЕсли;

		СотрудникРедмайн = ПолучитьПоле(Поля, 0);
		Если Не ПустаяСтрока(СотрудникРедмайн) Тогда
			ТекущийСотрудникРедмайн = СотрудникРедмайн;
		КонецЕсли;

		Если ПустаяСтрока(ТекущийСотрудникРедмайн) Тогда
			Продолжить;
		КонецЕсли;

		ПроектРедмайн = ПолучитьПоле(Поля, 1);
		Если ПустаяСтрока(ПроектРедмайн) Тогда
			Продолжить;
		КонецЕсли;

		Для ИндексДаты = 2 По Заголовок.Количество() - 1 Цикл

			ДатаРаботы = ПреобразоватьСтрокуВДату(Заголовок[ИндексДаты]);
			Если ДатаРаботы = Неопределено Тогда
				Продолжить;
			КонецЕсли;

			Часы = ПреобразоватьСтрокуВЧисло(ПолучитьПоле(Поля, ИндексДаты));
			Если Часы <= 0 Тогда
				Продолжить;
			КонецЕсли;

			ДобавитьСтрокуВыгрузки(ТекущийСотрудникРедмайн, ПроектРедмайн, Часы, ДатаРаботы);

		КонецЦикла;

	КонецЦикла;

КонецПроцедуры

&НаСервере
Процедура ЗагрузитьПострочныйФормат(ТаблицаCSV)

	ПерваяСтрока = ТаблицаCSV[0].Строка;
	Разделитель = ОпределитьРазделитель(ПерваяСтрока);
	Заголовок = РазобратьСтроку(ПерваяСтрока, Разделитель);

	КартаПолейИмпорта = ПостроитьКартуИмпортныхПолей(Заголовок);
	Если КартаПолейИмпорта = Неопределено Тогда
		Возврат;
	КонецЕсли;

	ТекущийСотрудникРедмайн = "";

	Для НомерСтроки = 1 По ТаблицаCSV.Количество() - 1 Цикл

		Поля = РазобратьСтроку(ТаблицаCSV[НомерСтроки].Строка, Разделитель);

		СотрудникРедмайн = ПолучитьПоле(Поля, КартаПолейИмпорта.Сотрудник);
		Если Не ПустаяСтрока(СотрудникРедмайн) Тогда
			ТекущийСотрудникРедмайн = СотрудникРедмайн;
		КонецЕсли;

		Если ПустаяСтрока(ТекущийСотрудникРедмайн) Тогда
			Продолжить;
		КонецЕсли;

		ПроектРедмайн = ПолучитьПоле(Поля, КартаПолейИмпорта.Проект);
		Часы = ПреобразоватьСтрокуВЧисло(ПолучитьПоле(Поля, КартаПолейИмпорта.Часы));
		ДатаРаботы = ПреобразоватьСтрокуВДату(ПолучитьПоле(Поля, КартаПолейИмпорта.Дата));

		Если Часы <= 0 Или ДатаРаботы = Неопределено Тогда
			Продолжить;
		КонецЕсли;

		ДобавитьСтрокуВыгрузки(ТекущийСотрудникРедмайн, ПроектРедмайн, Часы, ДатаРаботы);

	КонецЦикла;

КонецПроцедуры

&НаСервере
Функция ПостроитьКартуИмпортныхПолей(Заголовок) Экспорт

	Карта = Новый Структура;
	Карта.Вставить("Сотрудник", НайтиКолонкуПоСмыслам(Заголовок, Новый Массив("сотрудник", "пользователь", "исполнитель")));
	Карта.Вставить("Проект", НайтиКолонкуПоСмыслам(Заголовок, Новый Массив("проект", "задача")));
	Карта.Вставить("Часы", НайтиКолонкуПоСмыслам(Заголовок, Новый Массив("часы", "количествочасов", "время", "трудозатраты")));
	Карта.Вставить("Дата", НайтиКолонкуПоСмыслам(Заголовок, Новый Массив("дата", "день", "отчетзадату")));

	Если Карта.Сотрудник = Неопределено Или Карта.Проект = Неопределено
		Или Карта.Часы = Неопределено Или Карта.Дата = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;

	Возврат Карта;

КонецФункции

&НаСервере
Функция НайтиКолонкуПоСмыслам(Заголовок, Смыслы)

	Для Индекс = 0 По Заголовок.Количество() - 1 Цикл
		НормализованноеИмя = НормализоватьИмяПоля(Заголовок[Индекс]);
		Для Каждого Смысл Из Смыслы Цикл
			Если СтрНайти(НормализованноеИмя, Смысл) > 0 Тогда
				Возврат Индекс;
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;

	Возврат Неопределено;

КонецФункции

&НаСервере
Процедура ДобавитьСтрокуВыгрузки(СотрудникРедмайн, ПроектРедмайн, Часы, ДатаРаботы)

	НоваяСтрока = ТаблицаВыгрузки.Добавить();
	НоваяСтрока.Часы = Часы;
	НоваяСтрока.Дата = НачалоДня(ДатаРаботы);
	НоваяСтрока.СотрудникРедмайн = СотрудникРедмайн;
	НоваяСтрока.ПроектРедмайн = ПроектРедмайн;

	СтрокаСотрудника = НайтиСтрокуСопоставленияСотрудника(СотрудникРедмайн);
	Если СтрокаСотрудника <> Неопределено И ЗначениеЗаполнено(СтрокаСотрудника.СотрудникДО) Тогда
		НоваяСтрока.Сотрудник = СтрокаСотрудника.СотрудникДО;
	КонецЕсли;

	СтрокаПроекта = НайтиСтрокуСопоставленияПроекта(ПроектРедмайн);
	Если СтрокаПроекта <> Неопределено И ЗначениеЗаполнено(СтрокаПроекта.ПроектДО) Тогда
		НоваяСтрока.Проект = СтрокаПроекта.ПроектДО;
	КонецЕсли;

КонецПроцедуры

&НаСервере
Процедура ЗаполнитьСоответствияИзТаблицыВыгрузки()

	Для Каждого СтрокаВыгрузки Из ТаблицаВыгрузки Цикл
		ДобавитьСотрудникаВСопоставление(СтрокаВыгрузки.СотрудникРедмайн, СтрокаВыгрузки.Сотрудник);
		ДобавитьПроектВСопоставление(СтрокаВыгрузки.ПроектРедмайн, СтрокаВыгрузки.Проект);
	КонецЦикла;

КонецПроцедуры

&НаСервере
Процедура ДобавитьСотрудникаВСопоставление(СотрудникРедмайн, СотрудникДО)

	Если ПустаяСтрока(СотрудникРедмайн) Тогда
		Возврат;
	КонецЕсли;

	СтрокаСопоставления = НайтиСтрокуСопоставленияСотрудника(СотрудникРедмайн);
	Если СтрокаСопоставления = Неопределено Тогда
		СтрокаСопоставления = ТаблицаСотрудники.Добавить();
		СтрокаСопоставления.СотрудникРедмайн = СотрудникРедмайн;
	КонецЕсли;

	Если ЗначениеЗаполнено(СотрудникДО) Тогда
		СтрокаСопоставления.СотрудникДО = СотрудникДО;
	КонецЕсли;

КонецПроцедуры

&НаСервере
Процедура ДобавитьПроектВСопоставление(ПроектРедмайн, ПроектДО)

	Если ПустаяСтрока(ПроектРедмайн) Тогда
		Возврат;
	КонецЕсли;

	СтрокаСопоставления = НайтиСтрокуСопоставленияПроекта(ПроектРедмайн);
	Если СтрокаСопоставления = Неопределено Тогда
		СтрокаСопоставления = ТаблицаПроекты.Добавить();
		СтрокаСопоставления.ПроектРедмайн = ПроектРедмайн;
	КонецЕсли;

	Если ЗначениеЗаполнено(ПроектДО) Тогда
		СтрокаСопоставления.ПроектДО = ПроектДО;
	КонецЕсли;

КонецПроцедуры

&НаСервере
Процедура СопоставитьСотрудниковНаСервере()

	КартаСотрудников = Новый Соответствие;
	Для Каждого СтрокаСопоставления Из ТаблицаСотрудники Цикл
		Если ПустаяСтрока(СтрокаСопоставления.СотрудникРедмайн)
			Или Не ЗначениеЗаполнено(СтрокаСопоставления.СотрудникДО) Тогда
			Продолжить;
		КонецЕсли;

		КартаСотрудников.Вставить(
			НормализоватьИмяПоля(СтрокаСопоставления.СотрудникРедмайн),
			СтрокаСопоставления.СотрудникДО);
	КонецЦикла;

	Для Каждого СтрокаВыгрузки Из ТаблицаВыгрузки Цикл
		Ключ = НормализоватьИмяПоля(СтрокаВыгрузки.СотрудникРедмайн);
		Если ПустаяСтрока(Ключ) Тогда
			Продолжить;
		КонецЕсли;

		СотрудникДО = КартаСотрудников.Получить(Ключ);
		Если ЗначениеЗаполнено(СотрудникДО) Тогда
			СтрокаВыгрузки.Сотрудник = СотрудникДО;
		КонецЕсли;
	КонецЦикла;

КонецПроцедуры

&НаСервере
Процедура СопоставитьПроектыНаСервере()

	КартаПроектов = Новый Соответствие;
	Для Каждого СтрокаСопоставления Из ТаблицаПроекты Цикл
		Если ПустаяСтрока(СтрокаСопоставления.ПроектРедмайн)
			Или Не ЗначениеЗаполнено(СтрокаСопоставления.ПроектДО) Тогда
			Продолжить;
		КонецЕсли;

		КартаПроектов.Вставить(
			НормализоватьИмяПоля(СтрокаСопоставления.ПроектРедмайн),
			СтрокаСопоставления.ПроектДО);
	КонецЦикла;

	Для Каждого СтрокаВыгрузки Из ТаблицаВыгрузки Цикл
		Ключ = НормализоватьИмяПоля(СтрокаВыгрузки.ПроектРедмайн);
		Если ПустаяСтрока(Ключ) Тогда
			Продолжить;
		КонецЕсли;

		ПроектДО = КартаПроектов.Получить(Ключ);
		Если ЗначениеЗаполнено(ПроектДО) Тогда
			СтрокаВыгрузки.Проект = ПроектДО;
		КонецЕсли;
	КонецЦикла;

КонецПроцедуры

&НаСервере
Функция СоздатьДокументыДОНаСервере()

	СопоставитьСотрудниковНаСервере();
	СопоставитьПроектыНаСервере();

	КартаПолейДокумента = ПостроитьКартуСопоставленияПолей();
	Сообщения = Новый Массив;
	Если Не ПроверитьКартуСопоставленияПолей(КартаПолейДокумента, Сообщения) Тогда
		Возврат Строка(СоединитьСтроки(Сообщения, Символы.ПС));
	КонецЕсли;

	КлючиГрупп = Новый Соответствие;
	Для Каждого СтрокаВыгрузки Из ТаблицаВыгрузки Цикл

		Если СтрокаВыгрузки.Часы <= 0 Тогда
			Продолжить;
		КонецЕсли;

		Если Не ЗначениеЗаполнено(СтрокаВыгрузки.Сотрудник)
			Или Не ЗначениеЗаполнено(СтрокаВыгрузки.Проект)
			Или Не ЗначениеЗаполнено(СтрокаВыгрузки.Дата) Тогда
			Продолжить;
		КонецЕсли;

		КлючГруппы = Строка(СтрокаВыгрузки.Сотрудник) + "|" + Формат(НачалоДня(СтрокаВыгрузки.Дата), "ДФ=yyyyMMdd");
		Группа = КлючиГрупп.Получить(КлючГруппы);
		Если Группа = Неопределено Тогда
			Группа = Новый ТаблицаЗначений;
			Группа.Колонки.Добавить("Индекс", Новый ОписаниеТипов("Число"));
			КлючиГрупп.Вставить(КлючГруппы, Группа);
		КонецЕсли;

		НоваяСтрокаГруппы = Группа.Добавить();
		НоваяСтрокаГруппы.Индекс = ТаблицаВыгрузки.Индекс(СтрокаВыгрузки);

	КонецЦикла;

	ВидРаботПрограммирование = НайтиВидРаботПрограммирование();
	Если Не ЗначениеЗаполнено(ВидРаботПрограммирование) Тогда
		Сообщения.Добавить("Не найден вид работ 'Программирование' в каталоге 'ВидыРабот'.");
		Возврат Строка(СоединитьСтроки(Сообщения, Символы.ПС));
	КонецЕсли;

	СозданоДокументов = 0;
	ПропущеноДублей = 0;

	Для Каждого ЭлементКлюча Из КлючиГрупп Цикл
		Группа = ЭлементКлюча.Значение;
		Если Группа.Количество() = 0 Тогда
			Продолжить;
		КонецЕсли;

		ПерваяСтрока = ТаблицаВыгрузки[Группа[0].Индекс];
		Если ДокументЕжедневныйОтчетУжеСуществует(ПерваяСтрока.Сотрудник, ПерваяСтрока.Дата) Тогда
			ПропущеноДублей = ПропущеноДублей + 1;
			Сообщения.Добавить(
				СтрШаблон("Пропущен дубль документа по сотруднику %1 и дате %2.",
					Строка(ПерваяСтрока.Сотрудник),
					Формат(ПерваяСтрока.Дата, "ДФ=dd.MM.yyyy")));
			Продолжить;
		КонецЕсли;

		ДокументОбъект = Документы.ЕжедневныйОтчет.СоздатьДокумент();

		ЗаполнитьРеквизитЕслиСуществует(ДокументОбъект, КартаПолейДокумента.Шапка.Дата, ПерваяСтрока.Дата);
		ЗаполнитьРеквизитЕслиСуществует(ДокументОбъект, КартаПолейДокумента.Шапка.ОтчетЗа, ПерваяСтрока.Дата);
		ЗаполнитьРеквизитЕслиСуществует(ДокументОбъект, КартаПолейДокумента.Шапка.Сотрудник, ПерваяСтрока.Сотрудник);
		ЗаполнитьРеквизитЕслиСуществует(ДокументОбъект, КартаПолейДокумента.Шапка.Владелец, ПерваяСтрока.Сотрудник);

		Работы = СформироватьТаблицуРаботПоГруппе(Группа, ВидРаботПрограммирование, ПерваяСтрока.Дата);
		ДокументОбъект.ДополнительныеСвойства.Вставить("Работы", Работы);

		Попытка
			ДокументОбъект.Записать(РежимЗаписиДокумента.Проведение);
			СозданоДокументов = СозданоДокументов + 1;
		Исключение
			Сообщения.Добавить(
				СтрШаблон("Ошибка создания документа по сотруднику %1 и дате %2: %3",
					Строка(ПерваяСтрока.Сотрудник),
					Формат(ПерваяСтрока.Дата, "ДФ=dd.MM.yyyy"),
					ОписаниеОшибки()));
		КонецПопытки;
	КонецЦикла;

	Сообщения.Вставить(0, СтрШаблон("Создано документов: %1", СозданоДокументов));
	Сообщения.Вставить(1, СтрШаблон("Пропущено дублей: %1", ПропущеноДублей));
	Возврат Строка(СоединитьСтроки(Сообщения, Символы.ПС));

КонецФункции

