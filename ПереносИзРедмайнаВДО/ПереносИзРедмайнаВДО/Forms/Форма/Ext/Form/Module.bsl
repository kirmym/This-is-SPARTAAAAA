&НаСервере
Функция РазобратьСтроку(СтрокаCSV, Разделитель)

	Результат = Новый Массив;
	ТекущееПоле = "";
	ВКавычках = Ложь;
	ДлинаРазделителя = СтрДлина(Разделитель);
	Позиция = 1;

	Пока Позиция <= СтрДлина(СтрокаCSV) Цикл
		Символ = Сред(СтрокаCSV, Позиция, 1);

		Если КодСимвола(Символ) = 34 Тогда
			ВКавычках = Не ВКавычках;
			Позиция = Позиция + 1;
			Продолжить;
		КонецЕсли;

		Если Не ВКавычках И Сред(СтрокаCSV, Позиция, ДлинаРазделителя) = Разделитель Тогда
			Результат.Добавить(СокрЛП(ТекущееПоле));
			ТекущееПоле = "";
			Позиция = Позиция + ДлинаРазделителя;
			Продолжить;
		КонецЕсли;

		ТекущееПоле = ТекущееПоле + Символ;
		Позиция = Позиция + 1;
	КонецЦикла;

	Результат.Добавить(СокрЛП(ТекущееПоле));
	Возврат Результат;

КонецФункции

