Функция СформироватьТаблицуРаботПоГруппе(Группа, ВидРаботПрограммирование, ДатаДобавления)

	Работы = Новый ТаблицаЗначений;
	Работы.Колонки.Добавить("Работа", Новый ОписаниеТипов("Строка"));
	Работы.Колонки.Добавить("Длительность", Новый ОписаниеТипов("Число"));
	Работы.Колонки.Добавить("ВидРабот", Новый ОписаниеТипов("СправочникСсылка.ВидыРабот"));
	Работы.Колонки.Добавить("Источник", Новый ОписаниеТипов("ДокументСсылка.ЕжедневныйОтчет"));
	Работы.Колонки.Добавить("Проект", Новый ОписаниеТипов("СправочникСсылка.Проекты"));
	Работы.Колонки.Добавить("ПроектнаяЗадача", Новый ОписаниеТипов("СправочникСсылка.ПроектныеЗадачи"));
	Работы.Колонки.Добавить("ДатаДобавления", Новый ОписаниеТипов("Дата"));

	Для Каждого СтрокаГруппы Из Группа Цикл
		СтрокаВыгрузки = ТаблицаВыгрузки[СтрокаГруппы.Индекс];
		НоваяРабота = Работы.Добавить();
		НоваяРабота.Работа = "Работы по проекту";
		НоваяРабота.Длительность = Окр(СтрокаВыгрузки.Часы * 3600, 0);
		НоваяРабота.ВидРабот = ВидРаботПрограммирование;
		НоваяРабота.Проект = СтрокаВыгрузки.Проект;
		НоваяРабота.ДатаДобавления = ДатаДобавления;
	КонецЦикла;

	Возврат Работы;

