# ============================================
# КОНФИГУРАЦИЯ 1C METADATA TO NEO4J
# Документация: https://docs.onerpa.ru/mcp-servery-1c/servery/graph-metadata-search
# ============================================

# ============================================
# ОБЯЗАТЕЛЬНЫЕ ПАРАМЕТРЫ ЗАПОЛНИТЕ ВСЕ РАСКОММЕНТИРОВАННЫЕ ПАРАМЕТРЫ В ЭТОМ РАЗДЕЛЕ
# ============================================

# Лицензионный ключ (ОБЯЗАТЕЛЬНО)
# Требуется для запуска приложения
LICENSE_KEY=c2143f0b-960b-4dd5-aa4c-dc5305cdcd8c

# Вариант Docker-образа (по умолчанию: latest)
# Доступные варианты:
#   latest — amd64, с PyTorch (полная поддержка локальных embeddings, ~2.5 ГБ)
#   light  — amd64, без PyTorch (embeddings только через API, ~500 МБ)
#   arm64  — arm64, с PyTorch (для Apple Silicon / AWS Graviton / Raspberry Pi)
IMAGE_TAG=latest

# Директория с метаданными на ХОСТ-машине (ОБЯЗАТЕЛЬНО)
# Это основной параметр конфигурации. Укажите путь к директории с файлами метаданных .txt
# Docker автоматически смонтирует эту директорию в контейнер
# Пример: E:\OneAPAReport или C:\Projects\1C_Metadata
METADATA_HOST_PATH=E:/OneAPAREport

# Директория с детальными файлами метаданных на ХОСТ-машине (ОПЦИОНАЛЬНО)
# Используется для обогащения метаданных дополнительной информацией
# Docker автоматически смонтирует эту директорию в контейнер
# Оставьте пустым, если не используется
# Пример: E:\OneAPAReport_Details или C:\Projects\1C_Metadata_Details
# METADATA_FILES_HOST_PATH=

# API ключ (ОБЯЗАТЕЛЬНО)
# Используется для генерации бизнес-описаний и работы AI функций
# Поддерживаются: OpenAI, OpenRouter, Ollama, LM Studio и любые OpenAI-совместимые API
# Для локальных моделей укажите любое непустое значение
OPENAI_API_KEY=your-openai-key

# Базовый URL API (по умолчанию: https://api.openai.com/v1)
# Можно изменить для использования прокси или альтернативных endpoint'ов
# Для локальных моделей обычно http://127.0.0.1:1234/v1
# OPENAI_API_BASE=https://api.openai.com/v1

# Модель для генерации описаний (по умолчанию: gpt-5)
# Поддерживаемые: gpt-4, gpt-4o, gpt-3.5-turbo и т.д.
# OPENAI_MODEL=gpt-5

# Генерировать AI-описания для метаданных (по умолчанию: false)
# Если true, будут автоматически создаваться бизнес-описания объектов перед индексацией
# CALCULATE_BUSINESS_INFO=false

# API ключ для embeddings (опционально, по умолчанию используется основной OPENAI_API_KEY)
# Можно указать отдельный ключ, если embeddings используют другой аккаунт
# OPENAI_EMBEDDING_API_KEY=

# Базовый URL API для embeddings (опционально, по умолчанию используется OPENAI_API_BASE)
# OPENAI_EMBEDDING_API_BASE=https://api.openai.com/v1

# Модель для embeddings (по умолчанию: text-embedding-ada-002)
# Размерность векторов определяется автоматически!
# 
# Поддерживаемые модели (примеры):
# OpenAI модели:
#   - text-embedding-ada-002 (1536 измерений)
#   - text-embedding-3-small (1536 измерений)
#   - text-embedding-3-large (3072 измерения)
# 
# Qwen модели через Ollama:
#   - Qwen3-Embedding-4B (2560 измерений)
#   - Qwen3-Embedding-8B (размерность определяется автоматически)
# 
# Nomic модели через Ollama:
#   - nomic-embed-text (768 измерений)
# 
# E5 модели (офлайн через sentence-transformers):
#   - intfloat/multilingual-e5-small (384 измерения)
#   - intfloat/multilingual-e5-base (768 измерений)
#   - intfloat/multilingual-e5-large (1024 измерения)
# 
# Система автоматически определит размерность при первом запуске!
# OPENAI_EMBEDDING_MODEL=text-embedding-ada-002


# ============================================
# ВАЖНЫЕ ПАРАМЕТРЫ С ЗНАЧЕНИЯМИ ПО УМОЛЧАНИЮ
# Раскомментируйте для изменения значений
# ============================================

# Использовать SSE транспорт для MCP (по умолчанию: false)
# MCP_USE_SSE=false

# Режим суммаризации результатов (по умолчанию: false)
# Если true, результаты поиска будут сокращены до основных пунктов
# SUMMARIZE=false

# Режим отладки (по умолчанию: false)
# Если true, выводится дополнительная информация в логи
# DEBUG=false

# URI подключения к Neo4j (по умолчанию: bolt://localhost:7687)
# Для Docker обычно используется имя сервиса: bolt://neo4j:7687
# NEO4J_URI=bolt://localhost:7687

# Имя пользователя Neo4j (по умолчанию: neo4j)
# NEO4J_USERNAME=neo4j

# Пароль для Neo4j (по умолчанию: password123)
# ВАЖНО: Измените для production окружения!
# NEO4J_PASSWORD=password123

# Имя базы данных Neo4j (по умолчанию: neo4j)
# NEO4J_DATABASE=neo4j

# Хост MCP сервера (по умолчанию: 0.0.0.0)
# 0.0.0.0 означает прослушивание на всех сетевых интерфейсах
# MCP_HOST=0.0.0.0

# Порт MCP сервера (по умолчанию: 8006)
MCP_PORT=8016

# Путь для MCP endpoint (по умолчанию: /mcp)
# MCP_PATH=/mcp

# ============================================
# ПАРАМЕТРЫ ПОВЕДЕНИЯ И ФУНКЦИОНАЛЬНОСТИ
# Раскомментируйте для изменения значений
# ============================================

# Включить шаблонный режим поиска метаданных (по умолчанию: true)
# Если true, search_metadata принимает JSON-запросы с шаблонными операциями
# для мгновенных ответов без LLM (реквизиты, табличные части, формы и т.д.)
# TEMPLATE_MODE_ENABLED=true

# Режим "только шаблоны" (по умолчанию: false)
# Если true, search_metadata работает ТОЛЬКО с шаблонными JSON-запросами, LLM не используется.
# Полезно когда API недоступен или не нужен.
# Требует TEMPLATE_MODE_ENABLED=true
# TEMPLATE_MODE_ONLY=false

# Загружать структуру управляемых форм из XML (по умолчанию: false)
# Если true, система парсит Ext/Form.xml и создаёт ноды FormControl, FormEvent,
# FormAttribute, Command с иерархией и привязками к данным.
# Требует CODE_EXPORT_PATH (путь к XML-выгрузке конфигурации)
# LOAD_FORMS_FROM_XML=false

# Включить семантический поиск по бизнес-описаниям (по умолчанию: true)
# Если true, будет доступен поиск по смыслу, а не только по точному совпадению
# ENABLE_BUSINESS_SEARCH=true

# Генерировать embeddings для описательных полей метаданных (по умолчанию: false)
# Позволяет семантический поиск по Синоним, Комментарий, Описание, Справка
# При включении search_metadata_by_description автоматически использует гибридный режим
# (fulltext + vector) для более точного ранжирования результатов
# ENABLE_METADATA_DESCRIPTION_EMBEDDING=false

# Автоматическое обновление индексов при запуске (по умолчанию: true)
# Если true, векторные индексы будут обновлены автоматически при старте сервера
# AUTO_UPDATE_ON_STARTUP=true

# Асинхронная индексация векторов (по умолчанию: true)
# Если true, индексация будет выполняться в фоновом режиме
# ASYNC_VECTOR_INDEXING=true


# ============================================
# ПАРАМЕТРЫ ТОНКОЙ НАСТРОЙКИ
# Раскомментируйте для изменения значений
# ============================================

# Температура генерации (по умолчанию: 0.1)
# Значение от 0 до 1. Меньше - более детерминированные ответы, больше - более креативные
# OPENAI_TEMPERATURE=0.1

# Максимальное количество токенов в ответе (по умолчанию: 2000)
# OPENAI_MAX_COMPLETION_TOKENS=2000

# Модель для создания векторных представлений (по умолчанию: intfloat/multilingual-e5-small)
# Поддерживает многоязычность, включая русский язык
# EMBEDDING_MODEL=intfloat/multilingual-e5-small

# Разрешить автоматический переход на локальную модель, если API эмбеддингов недоступен (по умолчанию: true)
# Если false — при недоступности API индексация будет прервана с ошибкой.
# Рекомендуется false, если OPENAI_API_BASE настроен на внешний сервер.
# EMBEDDING_ALLOW_OFFLINE_FALLBACK=true

# Размер батча для индексации (по умолчанию: 50)
# Количество объектов, обрабатываемых за один раз при создании векторных индексов
# INDEX_BATCH_SIZE=50

# Максимальное количество токенов на батч для embeddings API (по умолчанию: 7500)
# Ограничение для предотвращения превышения лимита (8192 токена)
# Батчи будут автоматически разделены, если превышают этот лимит
# MAX_TOKENS_PER_BATCH=7500

# Максимальное количество токенов контекста для бизнес-описаний (по умолчанию: 4000)
# Включает XML + BSL код объекта
# BUSINESS_INFO_MAX_TOKENS=4000

# Количество повторных попыток при ошибках API (по умолчанию: 3)
# Используется экспоненциальная задержка между попытками
# BUSINESS_INFO_RETRY_COUNT=3

# Название проекта (по умолчанию: "1C Metadata Project")
# Используется для идентификации в логах и UI
# PROJECT_NAME=1C Metadata Project

# ============================================
# ПОДДЕРЖКА РАСШИРЕНИЙ КОНФИГУРАЦИИ
# ============================================

# Имя расширения (опционально)
# Если задано, все загружаемые объекты получают origin="extension" и extension_name.
# Без этого параметра объекты считаются базовыми (origin="base").
# EXTENSION_NAME=МоёРасширение

# Имя базового проекта, к которому привязывается расширение (опционально)
# Используется для построения связей EXTENDS/OVERRIDES между расширением и базой.
# Должно совпадать с PROJECT_NAME, использованным при загрузке базовой конфигурации.
# EXTENSION_BASE_PROJECT=1C Metadata Project

# ============================================
# ГРАФ BSL-КОДА (Module / Routine / CALLS)
# ============================================

# Путь к XML-выгрузке конфигурации (Конфигуратор → Выгрузить конфигурацию в файлы)
# Структура: CODE_EXPORT_PATH/Catalogs/Name/Ext/ObjectModule.bsl и т.д.
# CODE_EXPORT_PATH=

# Загружать сигнатуры BSL-кода в граф (по умолчанию: false)
# Если true, создаются ноды Module и Routine с графом вызовов CALLS
# Требует заполнения CODE_EXPORT_PATH
# LOAD_BSL_SIGNATURES=false

# Генерировать эмбеддинги для процедур/функций (Routine) (по умолчанию: true)
# Позволяет семантический поиск на уровне отдельных процедур/функций вместо целых объектов.
# Требует LOAD_BSL_SIGNATURES=true. Индексация запускается в фоновом потоке при старте сервера.
# ENABLE_ROUTINE_EMBEDDINGS=true

# ============================================
# ДОПОЛНИТЕЛЬНЫЕ ДАННЫЕ ИЗ XML-ВЫГРУЗКИ
# Все опции ниже требуют заполнения CODE_EXPORT_PATH
# ============================================

# Загружать подписки на события из EventSubscriptions/*.xml (по умолчанию: false)
# LOAD_EVENT_SUBSCRIPTIONS=false

# Загружать предопределённые элементы из */Predefined.xml (по умолчанию: false)
# LOAD_PREDEFINED_VALUES=false

# Загружать права ролей из Roles/*/Ext/Rights.xml (по умолчанию: false)
# LOAD_ROLE_RIGHTS=false

# Загружать справку объектов из */Help/ru.html (по умолчанию: false)
# LOAD_HELP_FROM_HTML=false

# Загружать структуру управляемых форм из XML (по умолчанию: false)
# LOAD_FORMS_FROM_XML=false
